{
  "admin": { "listen": "localhost:2019" },
  "logging": {
    "logs": {
      "default": { "level": "INFO" },
      "access": {
        "writer": {
          "output": "file",
          "filename": "/tmp/proxyos-access.log",
          "roll_size_mb": 100
        },
        "encoder": { "format": "json" },
        "include": ["http.log.access"]
      }
    }
  },
  "apps": {
    "http": {
      "servers": {
        "main": {
          "listen": [":80", ":443"],
          "routes": [],
          "logs": { "default_logger_name": "access" }
        }
      }
    },
    "tls": {
      "automation": {
        "policies": [
          {
            "issuers": [
              {
                "module": "acme",
                "challenges": {
                  "dns": {
                    "provider": {
                      "name": "cloudflare",
                      "api_token": "{env.CLOUDFLARE_API_TOKEN}"
                    }
                  }
                }
              }
            ]
          }
        ]
      }
    }
  }
}
