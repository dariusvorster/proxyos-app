{
  "admin": { "listen": "localhost:2019" },
  "logging": {
    "logs": {
      "default": {
        "level": "INFO",
        "writer": {
          "output": "file",
          "filename": "/data/proxyos/caddy-system.log",
          "roll_size_mb": 50
        }
      },
      "access": {
        "writer": {
          "output": "file",
          "filename": "/tmp/proxyos-access.log",
          "roll_size_mb": 100
        },
        "encoder": { "format": "json" },
        "include": ["http.log.access"]
      }
    }
  },
  "apps": {
    "http": {
      "servers": {
        "main": {
          "listen": [":80", ":443"],
          "routes": [],
          "logs": { "default_logger_name": "access" }
        }
      }
    },
    "tls": {
      "automation": {
        "policies": []
      }
    }
  }
}
