{
  "name": "proxyos",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm --filter @proxyos/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:push": "pnpm --filter @proxyos/db push",
    "db:studio": "pnpm --filter @proxyos/db studio"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.8.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3"]
  }
}
