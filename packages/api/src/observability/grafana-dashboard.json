{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "ProxyOS V3 — auto-generated dashboard for route traffic, agents, certificates, and connections",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Routes",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (route) (rate(proxyos_route_requests_total[5m]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "title": "Request rate by route",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "targets": [
        {
          "expr": "proxyos_route_request_duration_seconds{quantile=\"0.95\"}",
          "legendFormat": "{{route}} p95",
          "refId": "A"
        }
      ],
      "title": "p95 latency by route",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.05 }] } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 3,
      "targets": [
        {
          "expr": "sum by (route) (rate(proxyos_route_requests_total{status=\"5xx\"}[5m])) / sum by (route) (rate(proxyos_route_requests_total[5m]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "title": "5xx error rate by route",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "id": 4,
      "targets": [
        {
          "expr": "rate(proxyos_route_bytes_total[5m])",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "title": "Throughput (bytes/s) by route",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 101,
      "title": "Agents",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "OFFLINE", "color": "red" }, "1": { "text": "ONLINE", "color": "green" } } }], "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 18 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "proxyos_agent_status",
          "legendFormat": "{{agent}}",
          "refId": "A"
        }
      ],
      "title": "Agent status",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 18 },
      "id": 6,
      "targets": [
        {
          "expr": "proxyos_agent_routes_total",
          "legendFormat": "{{agent}}",
          "refId": "A"
        }
      ],
      "title": "Routes per agent",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 102,
      "title": "Certificates & Connections",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "d", "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 7 }, { "color": "yellow", "value": 30 }, { "color": "green", "value": 60 }] } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "id": 7,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "vertical", "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [
        {
          "expr": "proxyos_cert_expiry_days",
          "legendFormat": "{{domain}}",
          "refId": "A"
        }
      ],
      "title": "Certificate expiry (days)",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }], "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "id": 8,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "proxyos_connection_status",
          "legendFormat": "{{connection}} ({{type}})",
          "refId": "A"
        }
      ],
      "title": "Connection status",
      "type": "gauge"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["proxyos"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "ProxyOS V3",
  "uid": "proxyos-v3",
  "version": 1
}
